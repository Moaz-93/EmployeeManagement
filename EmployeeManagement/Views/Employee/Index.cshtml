@model IEnumerable<EmployeeManagement.Models.Employee>
@{
    ViewData["Title"] = "Employees";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="fa-solid fa-users"></i> Employees</h2>
    <a asp-action="Create" class="btn btn-success"><i class="fa-solid fa-plus"></i> Add Employee</a>
</div>
<form method="get" class="mb-4">
    <div class="input-group">
        <input type="text" name="searchTerm" class="form-control" placeholder="Search by employee name or department..." />
        <button type="submit" class="btn btn-primary"><i class="fa-solid fa-magnifying-glass"></i> Search</button>
    </div>
</form>
<div class="card text-center shadow-sm mb-4">
    <div class="card-body">
        <h6 class="text-muted">Total Employees</h6>
        <h1 class="fw-bold text-primary">@Model.Count()</h1>
    </div>
</div>
@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        No employees found.
        <a asp-action="Create">Create your first employee</a>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-bordered table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Job Title</th>
                        <th>Department</th>
                        <th>Hire Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.FullName</td>
                            <td>@item.Email</td>
                            <td>@item.JobTitle</td>
                            <td>@item.Department?.Name</td>
                            <td>@item.HireDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge rounded-pill bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-danger">Inactive</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm" title="Details"><i class="fa-solid fa-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm" title="Edit"><i class="fa-solid fa-pen"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm" title="Delete"><i class="fa-solid fa-trash"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}